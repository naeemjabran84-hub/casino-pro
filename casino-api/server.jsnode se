const express = require("express");
const cors = require("cors");

const app = express();

app.use(cors());

app.get("/", (req, res) => {
  res.send("Casino API running");
});

app.get("/dice", (req, res) => {
  res.json({
    roll: Math.floor(Math.random() * 6) + 1
  });
});

const PORT = process.env.PORT || 3000;

app.listen(PORT, () => {
  console.log("Casino running");
});


