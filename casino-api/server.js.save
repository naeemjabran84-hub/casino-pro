const express = require("express");
const cors = require("cors");

const app = express();
app.use(cors());

// Dice
app.get("/dice", (req, res) => {
  let roll = Math.floor(Math.random()*6)+1;
  res.json({ roll });
});

// Coin
app.get("/coin", (req, res) => {
  res.json({ win: Math.random() > 0.5 });
});

// Slot
app.get("/slot", (req, res) => {
  let symbols = ["🍒","🍋","🔔","💎","7️⃣"];
  let result = [
    symbols[Math.floor(Math.random()*symbols.length)],
    symbols[Math.floor(Math.random()*symbols.length)],
    symbols[Math.floor(Math.random()*symbols.length)]
  ];
  res.json(result);
});

app.listen(3000, "0.0.0.0", () => {
  console.log("Server running on port 3000");
});

const express = require("express");
const cors = require("cors");

const app = express();
app.use(cors());
app.use(express.json());

// simple database (temporary)
let users = {};

// REGISTER
app.post("/register", (req, res) => {
  let { username, password } = req.body;

  if (users[username]) {
    return res.json({ success: false, msg: "User exists" });
  }

  users[username] = { password, balance: 1000 };

  res.json({ success: true });
});

// LOGIN
app.post("/login", (req, res) => {
  let { username, password } = req.body;

  if (!users[username] || users[username].password !== password) {
    return res.json({ success: false });
  }

  res.json({ success: true, balance: users[username].balance });
});

// UPDATE BALANCE
app.post("/update", (req, res) => {
  let { username, balance } = req.body;

  if (users[username]) {
    users[username].balance = balance;
  }

  res.json({ success: true });
});

// GAMES
app.get("/dice", (req, res) => {
  res.json({ roll: Math.floor(Math.random()*6)+1 });
});

app.get("/coin", (req, res) => {
  res.json({ win: Math.random() > 0.5 });
});

app.get("/slot", (req, res) => {
  let s = ["🍒","🍋","🔔","💎","7️⃣"];
  res.json([
    s[Math.floor(Math.random()*s.length)],
    s[Math.floor(Math.random()*s.length)],
    s[Math.floor(Math.random()*s.length)]
  ]);
});

app.listen(3000, "0.0.0.0", () => {
  console.log("Server running with login system");
});
