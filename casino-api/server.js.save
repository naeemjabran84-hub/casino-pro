const express = require("express");
const cors = require("cors");
const mongoose = require("mongoose");
const bcrypt = require("bcrypt");
const jwt = require("jsonwebtoken");

const app = express();
app.use(cors());
app.use(express.json());

// 🔥 PUT YOUR MONGODB LINK HERE
mongoose.connect("YOUR_MONGODB_URL");

const UserSchema = new mongoose.Schema({
  username: String,
  password: String,
  balance: { type: Number, default: 1000 }
});

const User = mongoose.model("User", UserSchema);

// REGISTER
app.post("/register", async (req, res) => {
  const { username, password } = req.body;

  let exist = await User.findOne({ username });
  if (exist) return res.json({ success: false });

  let hash = await bcrypt.hash(password, 10);

  await User.create({ username, password: hash });

  res.json({ success: true });
});

// LOGIN
app.post("/login", async (req, res) => {
  const { username, password } = req.body;

  let user = await User.findOne({ username });
  if (!user) return res.json({ success: false });

  let ok = await bcrypt.compare(password, user.password);
  if (!ok) return res.json({ success: false });

  let token = jwt.sign({ id: user._id }, "secret");

  res.json({ success: true, token, balance: user.balance });
});

// AUTH MIDDLEWARE
async function auth(req, res, next) {
  try {
    let token = req.headers.authorization;
    let data = jwt.verify(token, "secret");
    req.user = await User.findById(data.id);
    next();
  } catch {
    res.status(401).send("Unauthorized");
  }
}

// UPDATE BALANCE
app.post("/update", auth, async (req, res) => {
  req.user.balance = req.body.balance;
  await req.user.save();
  res.json({ success: true });
});

// GAMES
app.get("/dice", (req, res) => {
  res.json({ roll: Math.floor(Math.random()*6)+1 });
});

app.get("/coin", (req, res) => {
  res.json({ win: Math.random() > 0.5 });
});

app.get("/slot", (req, res) => {
  let s = ["🍒","🍋","🔔","💎","7️⃣"];
  res.json([
    s[Math.floor(Math.random()*s.length)],
    s[Math.floor(Math.random()*s.length)],
    s[Math.floor(Math.random()*s.length)]
  ]);
});

app.listen(3000, () => console.log("PRO CASINO API RUNNING"));ls
